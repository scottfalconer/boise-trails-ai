  "legal_objects": {
    "run_loop": {
      "definition": "A continuous finite walk on G_run that starts and ends at the same legal parking vertex p in P.",
      "hard_constraints": [
        "start_parking_id == end_parking_id",
        "all edges are allowed in G_run",
        "no hidden car movement occurs inside the loop",
        "official direction rules are obeyed for direction-constrained segments",
        "continuous GPX passes max-gap threshold",
        "covered official segment geometry is verifiable against T"
      ]
    },
    "field_day": {
      "definition": "A home-to-home sequence H -> p1 -> run_loop_1 -> p2 -> run_loop_2 -> ... -> pk -> run_loop_k -> H with one car.",
      "hard_constraints": [
        "starts at H and ends at H",
        "car moves only through legal drive legs between H/P vertices",
        "each run loop returns to the currently parked car before any drive to another parking vertex",
        "daily p90 bounds B are satisfied"
      ],
      "cost_formula": "drive_p75(H,p1) + \u03a3 run_loop_p75(loop_i) + \u03a3 drive_p75(p_i,p_{i+1}) + drive_p75(pk,H) + transitions_p75"
    },
    "schedule": {
      "definition": "A finite set of feasible field days whose union covers every required official segment in T.",
      "coverage_constraint": "For every segment s in T, covered_length(schedule, s) >= required_length(s), with segment-id and geometry checks."
    }
  },
  "objective": {
    "type": "lexicographic_minimization",
    "primary": "total_p75_home_to_home_minutes",
    "tie_breakers_in_order": [
      "max_daily_stress_ratio",
      "total_p90_home_to_home_minutes",
      "total_grade_adjusted_miles",
      "total_on_foot_miles",
      "field_day_count",
      "total_parking_risk_score"
    ],
    "daily_stress_ratio_formula": "max(metric_value / bound_value for every active daily bound metric)"
  },
  "solver_certificate_requirements": {
    "feasibility_certificate": [
      "full official segment coverage",
      "single-car run-loop continuity",
      "home-to-home field days",
      "legal running edges only",
      "legal drive legs only",
      "direction rules obeyed",
      "p90 daily bounds obeyed",
      "continuous GPX for every run loop"
    ],
    "optimality_certificate": [
      "incumbent objective upper bound",
      "global lower bound over declared graph/universe",
      "zero optimality gap for primary objective",
      "lexicographic tie-break certificate or domination certificate"
    ],
    "independent_checker_required": true
  },
