<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="boise-trails-ai" xmlns="http://www.topografix.com/GPX/1/1">
  <metadata>
    <name>FD06A Lower Interpretive cues</name>
    <desc>FD06A. Lower Interpretive | Official 4.09 mi; On-foot 8.59 mi; Door-to-door p75 3h 40m; Segments left 3 / 3. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.650358" lon="-116.143598">
    <name>PARK/START Lower Interpretive Trailhead</name>
    <desc>Park here and start this outing.</desc>
  </wpt>
  <wpt lat="43.644017" lon="-116.134622">
    <name>CUE 01 Fat Tire Traverse</name>
    <desc>Follow Fat Tire Traverse. First official segment here: Fat Tire Traverse 1. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.640089" lon="-116.132762">
    <name>CUE 02 Curlew Connection</name>
    <desc>Follow Curlew Connection. First official segment here: Curlew Connection 1. ASCENT REQUIRED. ASCENT REQUIRED: follow map arrows uphill. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.650300" lon="-116.143600">
    <name>RETURN TO CAR</name>
    <desc>Route endpoint / return-to-car point.</desc>
  </wpt>
</gpx>
