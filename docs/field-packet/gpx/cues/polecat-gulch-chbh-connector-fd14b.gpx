  <metadata>
    <name>Polecat Gulch: CHBH Connector (FD14B) cues</name>
    <desc>FD14B. Cartwright | Official 1.29 mi; On-foot 5.08 mi; Door-to-door p75 1h 43m; Segments left 2 / 2. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.689730" lon="-116.219917">
    <name>PARK/START Cartwright Trailhead</name>
    <desc>Park here and start this outing.</desc>
  </wpt>
  <wpt lat="43.674767" lon="-116.223074">
    <name>CUE 01 CHBH Connector</name>
    <desc>Follow CHBH Connector. First official segment here: CHBH Connector 1. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.681991" lon="-116.220487">
    <name>CUE 02 Quick Draw</name>
    <desc>Follow Quick Draw. First official segment here: Quick Draw 1. Either direction allowed; planned opposite official geometry. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.689700" lon="-116.219900">
    <name>RETURN TO CAR</name>
    <desc>Route endpoint / return-to-car point.</desc>
