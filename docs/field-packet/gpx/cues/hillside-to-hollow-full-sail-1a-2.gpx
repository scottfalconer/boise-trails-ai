  <metadata>
    <name>Hillside to Hollow: Full Sail (1A-2) cues</name>
    <desc>1A-2. West Climb | Official 3.13 mi; On-foot 4.86 mi; Door-to-door p75 1h 47m; Segments left 9 / 9. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.650998" lon="-116.224045">
    <name>PARK/START West Climb Trailhead</name>
    <desc>Park here and start this outing.</desc>
  </wpt>
  <wpt lat="43.651018" lon="-116.224797">
    <name>CUE 01 Full Sail Trail</name>
    <desc>Follow Full Sail Trail. First official segment here: Full Sail Trail. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.654571" lon="-116.224828">
    <name>CUE 02 #53 Buena Vista Trail</name>
    <desc>Follow #53 Buena Vista Trail. First official segment here: Buena Vista Trail. Signpost: #53 Buena Vista Trail. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.650479" lon="-116.219246">
    <name>CUE 03 Bob Smylie</name>
    <desc>Follow Bob Smylie. First official segment here: Bob Smylie. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.650998" lon="-116.224045">
    <name>RETURN TO CAR</name>
    <desc>Route endpoint / return-to-car point.</desc>
  </wpt>
</gpx>
