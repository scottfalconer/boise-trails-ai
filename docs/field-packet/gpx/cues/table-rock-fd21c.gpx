  </wpt>
  <wpt lat="43.604538" lon="-116.159203">
    <name>CUE 02 Quarry Trail - Castle Rock</name>
    <desc>Follow Quarry Trail - Castle Rock. First official segment here: Quarry Trail - Castle Rock 1. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.608159" lon="-116.168142">
    <name>CUE 03 Shoshone-Paiute</name>
    <desc>Follow Shoshone-Paiute. First official segment here: Shoshone-Paiute 2. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.603700" lon="-116.162400">
    <name>RETURN TO CAR</name>
    <desc>Route endpoint / return-to-car point.</desc>
  </wpt>
