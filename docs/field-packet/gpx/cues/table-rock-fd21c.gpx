  <metadata>
    <name>Table Rock (FD21C) cues</name>
    <desc>FD21C. Old Pen | Official 2.34 mi; On-foot 6.86 mi; Door-to-door p75 1h 55m; Segments left 14 / 14. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.603667" lon="-116.162383">
    <name>PARK/START Old Pen Trailhead</name>
    <desc>Park here and start this outing.</desc>
  </wpt>
