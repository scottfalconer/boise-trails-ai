  <metadata>
    <name>8 Homestead cues</name>
    <desc>8. Homestead | Official 2.26 mi; On-foot 4.05 mi; Door-to-door p75 1h 48m; Segments left 3 / 3. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.572108" lon="-116.113852">
    <name>PARK/START Homestead Trail Access Point</name>
    <desc>Park here and start this outing.</desc>
  </wpt>
  <wpt lat="43.572158" lon="-116.106094">
    <name>CUE 01 Harris Ridge Trail</name>
    <desc>Follow Harris Ridge Trail. First official segment here: Harris Ridge Trail 1. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.566296" lon="-116.105078">
    <name>CUE 02 Peace Valley Overlook</name>
    <desc>Follow Peace Valley Overlook. First official segment here: Peace Valley Overlook 2. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.572100" lon="-116.114000">
    <name>RETURN TO CAR</name>
    <desc>Route endpoint / return-to-car point.</desc>
  </wpt>
