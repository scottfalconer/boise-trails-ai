  <metadata>
    <name>5 Cartwright cues</name>
    <desc>5. Cartwright | Official 7.99 mi; On-foot 13.56 mi; Door-to-door p75 3h 41m; Segments left 11 / 11. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.689730" lon="-116.219917">
    <name>PARK/START Cartwright Trailhead</name>
    <desc>Park here and start this outing.</desc>
