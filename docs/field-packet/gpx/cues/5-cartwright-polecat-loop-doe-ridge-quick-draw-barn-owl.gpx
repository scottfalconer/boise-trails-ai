    <desc>Follow Quick Draw. First official segment here: Quick Draw 1. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.711213" lon="-116.244614">
    <name>CUE 04 Barn Owl</name>
    <desc>Follow Barn Owl. First official segment here: Barn Owl 1. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.689700" lon="-116.219900">
