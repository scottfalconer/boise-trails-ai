    <name>CUE 01 Highlands Trail</name>
    <desc>Follow Highlands Trail. First official segment here: Highlands Trail. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.674906" lon="-116.179640">
    <name>CUE 02 Connector</name>
    <desc>Follow Connector. First official segment here: Connector. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.658645" lon="-116.174252">
    <name>RETURN TO CAR</name>
    <desc>Route endpoint / return-to-car point.</desc>
