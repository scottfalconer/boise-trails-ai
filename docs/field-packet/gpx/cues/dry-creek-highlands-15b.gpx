  <metadata>
    <name>Dry Creek: Highlands (15B) cues</name>
    <desc>15B. Bob's | Official 2.35 mi; On-foot 8.43 mi; Door-to-door p75 2h 27m; Segments left 3 / 3. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.658556" lon="-116.174261">
    <name>PARK/START Bob's Trailhead</name>
