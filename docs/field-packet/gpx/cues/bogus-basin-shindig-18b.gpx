<gpx version="1.1" creator="boise-trails-ai" xmlns="http://www.topografix.com/GPX/1/1">
  <metadata>
    <name>Bogus Basin: Shindig (18B) cues</name>
    <desc>18B. Simplot Lodge Parking Area | Official 0.66 mi; On-foot 6.82 mi; Door-to-door p75 2h 45m; Segments left 2 / 2. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.764574" lon="-116.105566">
    <name>PARK/START Simplot Lodge Parking Area</name>
    <desc>Park here and start this outing.</desc>
  </wpt>
  <wpt lat="43.760899" lon="-116.088450">
    <name>CUE 01 Shindig</name>
    <desc>Follow Shindig. First official segment here: Shindig 2. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.774860" lon="-116.092292">
    <name>CUE 02 Lodge Trail</name>
    <desc>Follow Lodge Trail. First official segment here: Lodge Trail 1. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.764574" lon="-116.105566">
    <name>RETURN TO CAR</name>
    <desc>Route endpoint / return-to-car point.</desc>
  </wpt>
</gpx>
