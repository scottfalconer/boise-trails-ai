  <metadata>
    <name>7 Seamans Gulch cues</name>
    <desc>7. Seamans Gulch | Official 2.25 mi; On-foot 3.77 mi; Door-to-door p75 1h 41m; Segments left 6 / 6. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.693445" lon="-116.278528">
    <name>PARK/START Seamans Gulch Trailhead</name>
    <desc>Park here and start this outing.</desc>
  </wpt>
  <wpt lat="43.691431" lon="-116.282256">
    <name>CUE 01 Seaman Gulch Trail</name>
    <desc>Follow Seaman Gulch Trail. First official segment here: Seaman Gulch Trail 1. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.689610" lon="-116.277470">
    <name>CUE 02 Wild Phlox Trail</name>
    <desc>Follow Wild Phlox Trail. First official segment here: Wild Phlox Trail 1. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.693400" lon="-116.278500">
    <name>RETURN TO CAR</name>
    <desc>Route endpoint / return-to-car point.</desc>
  </wpt>
