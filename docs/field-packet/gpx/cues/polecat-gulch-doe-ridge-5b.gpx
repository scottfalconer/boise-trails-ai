    <desc>5B. Cartwright | Official 5.14 mi; On-foot 5.59 mi; Door-to-door p75 2h 37m; Segments left 8 / 8. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.689730" lon="-116.219917">
    <name>PARK/START Cartwright Trailhead</name>
    <desc>Park here and start this outing.</desc>
  </wpt>
