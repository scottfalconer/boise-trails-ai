  <metadata>
    <name>Polecat Gulch: Polecat Loop (FD18A) cues</name>
    <desc>FD18A. Cartwright | Official 10.19 mi; On-foot 14.36 mi; Door-to-door p75 4h 14m; Segments left 8 / 8. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.689730" lon="-116.219917">
    <name>PARK/START Cartwright Trailhead</name>
    <desc>Park here and start this outing.</desc>
  </wpt>
  <wpt lat="43.689700" lon="-116.220000">
    <name>CAR PASS 1</name>
    <desc>Pass by the parked car again near mile 6.09.</desc>
  </wpt>
  <wpt lat="43.689338" lon="-116.220002">
    <name>CUE 01 #81 Polecat Loop</name>
    <desc>Follow #81 Polecat Loop. First official segment here: Polecat Loop 1. Signpost: #81 Polecat Loop. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.695837" lon="-116.205471">
    <name>CUE 02 Peggy's Trail</name>
    <desc>Follow Peggy's Trail. First official segment here: Peggy's Trail 1. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.689700" lon="-116.219900">
    <name>RETURN TO CAR</name>
    <desc>Route endpoint / return-to-car point.</desc>
  </wpt>
