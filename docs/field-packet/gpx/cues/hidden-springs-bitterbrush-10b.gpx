  <metadata>
    <name>Hidden Springs: Bitterbrush (10B) cues</name>
    <desc>10B. Dry Creek Parking Area/Trailhead | Official 2.45 mi; On-foot 4.28 mi; Door-to-door p75 2h 32m; Segments left 4 / 4. Check current Ridge to Rivers signage and conditions before leaving.</desc>
  </metadata>
  <wpt lat="43.725463" lon="-116.248180">
    <name>PARK/START Dry Creek Parking Area/Trailhead</name>
    <desc>Park here and start this outing.</desc>
  </wpt>
  <wpt lat="43.725650" lon="-116.248050">
    <name>CAR PASS 1</name>
    <desc>Pass by the parked car again near mile 5.24.</desc>
  </wpt>
  <wpt lat="43.723661" lon="-116.237658">
    <name>CUE 01 Bitterbrush Trail</name>
    <desc>Follow Bitterbrush Trail. First official segment here: Bitterbrush Trail 1. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.724729" lon="-116.232786">
    <name>CUE 02 Currant Creek</name>
    <desc>Follow Currant Creek. First official segment here: Currant Creek 3. Either direction allowed; follow map arrows. This is a navigation cue, not the full segment-credit audit.</desc>
  </wpt>
  <wpt lat="43.725463" lon="-116.248180">
    <name>RETURN TO CAR</name>
    <desc>Route endpoint / return-to-car point.</desc>
  </wpt>
